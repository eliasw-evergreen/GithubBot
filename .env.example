REOPENED_REACTION=
READY_FOR_REVIEW_REACTION=
CONVERTED_TO_DRAFT_REACTION=
MERGED_REACTION=
CLOSED_REACTION=
APPROVED_REACTION=
CHANGES_REQUESTED_REACTION=
COMMENT_REACTION=

PRUNE_DAYS=14
PORT=3000
